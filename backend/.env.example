# ============================================================================
# ArtShop Backend - Environment Configuration
# Copy this to .env and fill in your values
# ============================================================================

# Server
PORT=8080
ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Supabase Database (get from Supabase Dashboard → Settings → Database)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_HOURS=168

# Supabase Storage (for file uploads)
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
STORAGE_BUCKET=artshop-images

# AI Integration (Google Gemini) — free tier at https://aistudio.google.com/app/apikey
# Leave GEMINI_API_KEY empty to disable generative AI (description/tags generation).
# Product recommendations keep working either way — they use SQL, not AI.
GEMINI_API_KEY=
AI_MODEL=gemini-2.0-flash

# Email (Brevo) — https://app.brevo.com/settings/keys/api
# Verify your sender address in Brevo → Senders & IP → Senders before sending.
# A single verified email works without owning a domain.
BREVO_API_KEY=
EMAIL_FROM_NAME=ArtShop
EMAIL_FROM_ADDRESS=your-verified-sender@example.com

# Public URL of the frontend, used to build links inside emails (password reset, etc.).
APP_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200
